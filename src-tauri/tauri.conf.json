{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenMV Studio",
  "version": "0.1.0",
  "identifier": "com.openmv.studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "OpenMV Studio",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../resources": "resources"
    },
    "externalBin": [
      "binaries/dfu-util/dfu-util"
    ]
  }
}
